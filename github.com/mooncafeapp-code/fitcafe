    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modal-member')">İptal</button>
      <button class="btn btn-accent" onclick="saveMember()">Kaydet</button>
    </div>
  </div>
</div>
<div class="modal-overlay" id="modal-balance">
  <div class="modal">
    <div class="modal-title">BAKİYE EKLE</div>
    <div id="balance-member-name" style="color:var(--muted);margin-bottom:16px;font-size:14px"></div>
    <div class="form-grid">
      <div class="form-group"><label>Miktar (₺)</label><input id="bal-amount" type="number" placeholder="100"></div>
      <div class="form-group"><label>Not</label><input id="bal-note" placeholder="Aylık yükleme"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modal-balance')">İptal</button>
      <button class="btn btn-accent" onclick="saveBalance()">Yükle</button>
    </div>
  </div>
</div>
<div class="modal-overlay" id="modal-product">
  <div class="modal">
    <div class="modal-title" id="modal-product-title">YENİ ÜRÜN</div>
    <div class="form-grid">
      <div class="form-group"><label>Emoji</label><input id="p-emoji" placeholder="☕" maxlength="4"></div>
      <div class="form-group"><label>Ürün Adı *</label><input id="p-name" placeholder="Protein Shake"></div>
      <div class="form-group"><label>Fiyat (₺) *</label><input id="p-price" type="number" placeholder="75"></div>
      <div class="form-group"><label>Kategori</label><select id="p-cat"><option>İçecek</option><option>Yiyecek</option><option>Supplement</option><option>Diğer</option></select></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modal-product')">İptal</button>
      <button class="btn btn-accent" onclick="saveProduct()">Kaydet</button>
    </div>
  </div>
</div>
<div class="modal-overlay" id="modal-monthend-confirm">
  <div class="modal">
    <div class="modal-title">AY SONU ONAYI</div>
    <div id="monthend-confirm-text" style="color:var(--muted);margin-bottom:20px;font-size:14px;line-height:1.6"></div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modal-monthend-confirm')">İptal</button>
      <button class="btn btn-red" onclick="confirmMonthEnd()">Evet, Uygula</button>
    </div>
  </div>
</div>

<div class="bottom-nav">
  <div class="bottom-nav-inner">
    <div class="bnav-item active" onclick="goPage('dashboard')"><span class="bnav-icon">📊</span>Panel</div>
    <div class="bnav-item" onclick="goPage('members')"><span class="bnav-icon">👥</span>Üyeler</div>
    <div class="bnav-item" onclick="goPage('sale')"><span class="bnav-icon">🛒</span>Satış</div>
    <div class="bnav-item" onclick="goPage('products')"><span class="bnav-icon">🥤</span>Ürünler</div>
    <div class="bnav-item" onclick="goPage('monthend')"><span class="bnav-icon">📅</span>Ay Sonu</div>
    <div class="bnav-item" onclick="goPage('report')"><span class="bnav-icon">📈</span>Rapor</div>
  </div>
</div>
