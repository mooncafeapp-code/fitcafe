<script>
const SUPA_URL = 'https://jjqzghnpcfkmhiuxqwol.supabase.co';
const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpqcXpnaG5wY2ZrbWhpdXhxd29sIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2MDI4NzYsImV4cCI6MjA4OTE3ODg3Nn0.b3HTTiJdJ52-SZae0iKA5srgF7S5wyIL254o2XLh7b0';

async function db(table, method, body, query) {
  method = method || 'GET'; query = query || '';
  const res = await fetch(SUPA_URL + '/rest/v1/' + table + query, {
    method,
    headers: {
      'apikey': SUPA_KEY,
      'Authorization': 'Bearer ' + SUPA_KEY,
      'Content-Type': 'application/json',
      'Prefer': (method === 'POST' || method === 'PATCH') ? 'return=representation' : ''
    },
    body: body ? JSON.stringify(body) : undefined
  });
  if (!res.ok) throw new Error(await res.text());
  const txt = await res.text();
  return txt ? JSON.parse(txt) : null;
}

let MEMBERS = [], PRODUCTS = [], TRANSACTIONS = [];

async function loadAll() {
  const [m, p, t] = await Promise.all([
    db('uyeler', 'GET', null, '?order=ad_soyad.asc'),
    db('urunler', 'GET', null, '?order=ad.asc'),
    db('islemler', 'GET', null, '?order=id.desc')
  ]);
  MEMBERS = m || []; PRODUCTS = p || []; TRANSACTIONS = t || [];
}

function today() { return new Date().toISOString().split('T')[0]; }
function fmt(d) { return new Date(d).toLocaleDateString('tr-TR', {day:'2-digit',month:'short',year:'2-digit'}); }
function fmtMoney(n) { return '₺' + Math.abs(Number(n)||0).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,'.'); }

function toast(msg, err) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (err ? ' error' : '');
  setTimeout(() => t.className = 'toast', 2800);
}
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function goPage(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item,.bnav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  const kw = {dashboard:'panel',members:'üye',sale:'satış',products:'ürün',monthend:'ay sonu',report:'rapor'}[page];
  document.querySelectorAll('.nav-item,.bnav-item').forEach(n => {
    if (n.textContent.trim().toLowerCase().includes(kw)) n.classList.add('active');
  });
  if (page === 'dashboard') renderDashboard();
  if (page === 'members') renderMembers();
  if (page === 'sale') renderSalePage();
  if (page === 'products') renderProducts();
  if (page === 'monthend') renderMonthEnd();
  if (page === 'report') { populateMonthSelect('report-month'); renderReport(); }
}

// DASHBOARD
function renderDashboard() {
  const month = today().slice(0,7);
  const monthSales = TRANSACTIONS.filter(t => t.tur==='satis' && t.tarih.startsWith(month)).reduce((s,t)=>s+Number(t.tutar),0);
  const negCount = MEMBERS.filter(m => Number(m.bakiye)<0).length;
  document.getElementById('dash-cards').innerHTML = `
    <div class="card"><div class="card-label">Toplam Üye</div><div class="card-value" style="color:var(--text)">${MEMBERS.length}</div></div>
    <div class="card"><div class="card-label">Bu Ay Satış</div><div class="card-value orange">${fmtMoney(monthSales)}</div></div>
    <div class="card"><div class="card-label">Negatif Bakiye</div><div class="card-value red">${negCount} üye</div></div>
    <div class="card"><div class="card-label">Ürün Çeşidi</div><div class="card-value green">${PRODUCTS.length}</div></div>`;
  const recent = TRANSACTIONS.slice(0,10);
  document.getElementById('dash-tx-count').textContent = TRANSACTIONS.length + ' toplam işlem';
  document.getElementById('dash-tx').innerHTML = recent.map(t => {
    const m = MEMBERS.find(x => x.id===t.uye_id);
    const badge = t.tur==='yukleme' ? '<span class="badge pos">Yükleme</span>' : t.tur==='devir' ? '<span class="badge warn">Devir</span>' : '<span class="badge neg">Satış</span>';
    const neg = t.tur==='satis'||t.tur==='devir';
    return `<tr><td>${m?m.ad_soyad:'—'}</td><td>${badge} <span style="color:var(--muted);font-size:12px">${t.aciklama||''}</span></td><td><span class="balance-chip ${neg?'balance-neg':'balance-pos'}">${neg?'-':'+'}${fmtMoney(t.tutar)}</span></td><td style="color:var(--muted);font-size:13px">${fmt(t.tarih)}</td></tr>`;
  }).join('') || '<tr><td colspan="4" style="color:var(--muted);text-align:center;padding:24px">Henüz işlem yok</td></tr>';
}

// MEMBERS
let memberSearch = '';
function renderMembers(search) {
  if (search !== undefined) memberSearch = search;
  const q = memberSearch.toLowerCase();
  const month = today().slice(0,7);
  const filtered = MEMBERS.filter(m => m.ad_soyad.toLowerCase().includes(q)||(m.telefon&&m.telefon.includes(q)));
  document.getElementById('members-table').innerHTML = filtered.map(m => {
    const spent = TRANSACTIONS.filter(t=>t.uye_id===m.id&&t.tur==='satis'&&t.tarih.startsWith(month)).reduce((s,t)=>s+Number(t.tutar),0);
    const pct = m.aylik_limit>0 ? Math.min(100,(spent/m.aylik_limit)*100) : 0;
    const bal = Number(m.bakiye);
    const bc = bal>0?'balance-pos':bal<0?'balance-neg':'balance-zero';
    const status = bal<0?'<span class="badge neg">Ekside</span>':spent>=m.aylik_limit?'<span class="badge warn">Limit Doldu</span>':'<span class="badge pos">Aktif</span>';
    return `<tr>
      <td><strong>${m.ad_soyad}</strong></td>
      <td style="color:var(--muted);font-size:13px">${m.telefon||'—'}</td>
      <td><span style="font-family:'JetBrains Mono',monospace">${fmtMoney(m.aylik_limit)}</span>
        <div style="margin-top:4px;background:var(--border);border-radius:4px;height:4px;width:80px"><div style="background:${pct>=100?'var(--red)':'var(--accent)'};height:4px;border-radius:4px;width:${pct}%"></div></div>
        <div style="font-size:11px;color:var(--muted);margin-top:2px">${fmtMoney(spent)} harcandı</div></td>
      <td><span class="balance-chip ${bc}">${bal>=0?'+':''}${fmtMoney(bal)}</span></td>
      <td>${status}</td>
      <td><div style="display:flex;gap:6px;flex-wrap:wrap">
        <button class="btn btn-outline btn-sm" onclick="openBalanceModal(${m.id})">+ Bakiye</button>
        <button class="btn btn-outline btn-sm" onclick="openEditMember(${m.id})">✏️</button>
        <button class="btn btn-red btn-sm" onclick="deleteMember(${m.id})">🗑</button>
      </div></td>
    </tr>`;
  }).join('') || '<tr><td colspan="6" style="color:var(--muted);text-align:center;padding:24px">Üye bulunamadı</td></tr>';
}

let editingMemberId = null;
function openAddMember() {
  editingMemberId = null;
  document.getElementById('modal-member-title').textContent = 'YENİ ÜYE';
  ['m-name','m-phone','m-limit','m-balance'].forEach(id => document.getElementById(id).value='');
  openModal('modal-member');
}
function openEditMember(id) {
  editingMemberId = id;
  const m = MEMBERS.find(x=>x.id===id);
  document.getElementById('modal-member-title').textContent = 'ÜYEYİ DÜZENLE';
  document.getElementById('m-name').value = m.ad_soyad;
  document.getElementById('m-phone').value = m.telefon||'';
  document.getElementById('m-limit').value = m.aylik_limit;
  document.getElementById('m-balance').value = m.bakiye;
  openModal('modal-member');
}
async function saveMember() {
  const name = document.getElementById('m-name').value.trim();
  const limit = parseFloat(document.getElementById('m-limit').value);
  if (!name||isNaN(limit)) { toast('Ad ve limit zorunlu!',true); return; }
  const phone = document.getElementById('m-phone').value.trim();
  const balance = parseFloat(document.getElementById('m-balance').value)||0;
  try {
    if (editingMemberId) {
      await db('uyeler','PATCH',{ad_soyad:name,telefon:phone,aylik_limit:limit,bakiye:balance},`?id=eq.${editingMemberId}`);
    } else {
      const res = await db('uyeler','POST',{ad_soyad:name,telefon:phone,aylik_limit:limit,bakiye:balance,kayit_tarihi:today()});
      const newM = Array.isArray(res) ? res[0] : res;
      if (balance!==0) await db('islemler','POST',{uye_id:newM.id,tur:'yukleme',tutar:Math.abs(balance),tarih:today(),aciklama:'Başlangıç bakiyesi'});
    }
    await loadAll(); closeModal('modal-member'); renderMembers(); renderDashboard();
    toast(editingMemberId?'Üye güncellendi ✓':'Üye eklendi ✓');
  } catch(e) { toast('Hata: '+e.message,true); }
}
async function deleteMember(id) {
  if (!confirm('Bu üyeyi silmek istediğinizden emin misiniz?')) return;
  try {
    await db('islemler','DELETE',null,`?uye_id=eq.${id}`);
    await db('uyeler','DELETE',null,`?id=eq.${id}`);
    await loadAll(); renderMembers(); renderDashboard(); toast('Üye silindi');
  } catch(e) { toast('Hata: '+e.message,true); }
}

let balanceMemberId = null;
function openBalanceModal(id) {
  balanceMemberId = id;
  const m = MEMBERS.find(x=>x.id===id);
  document.getElementById('balance-member-name').textContent = m.ad_soyad + ' — Mevcut: ' + (Number(m.bakiye)>=0?'+':'') + fmtMoney(m.bakiye);
  document.getElementById('bal-amount').value=''; document.getElementById('bal-note').value='';
  openModal('modal-balance');
}
async function saveBalance() {
  const amount = parseFloat(document.getElementById('bal-amount').value);
  if (isNaN(amount)||amount===0) { toast('Geçerli bir miktar girin!',true); return; }
  const m = MEMBERS.find(x=>x.id===balanceMemberId);
  try {
    await db('uyeler','PATCH',{bakiye:Number(m.bakiye)+amount},`?id=eq.${balanceMemberId}`);
    await db('islemler','POST',{uye_id:balanceMemberId,tur:'yukleme',tutar:Math.abs(amount),tarih:today(),aciklama:document.getElementById('bal-note').value||'Bakiye yükleme'});
    await loadAll(); closeModal('modal-balance'); renderMembers(); renderDashboard(); toast('Bakiye yüklendi ✓');
  } catch(e) { toast('Hata: '+e.message,true); }
}

// PRODUCTS
function renderProducts() {
  document.getElementById('products-table').innerHTML = PRODUCTS.map(p => `
    <tr>
      <td style="font-size:22px">${p.emoji||'🛒'}</td>
      <td><strong>${p.ad}</strong></td>
      <td><span style="font-family:'JetBrains Mono',monospace;color:var(--accent)">${fmtMoney(p.fiyat)}</span></td>
      <td><span class="badge pos">${p.kategori||'—'}</span></td>
      <td><div style="display:flex;gap:6px">
        <button class="btn btn-outline btn-sm" onclick="openEditProduct(${p.id})">✏️</button>
        <button class="btn btn-red btn-sm" onclick="deleteProduct(${p.id})">🗑</button>
      </div></td>
    </tr>`).join('')||'<tr><td colspan="5" style="color:var(--muted);text-align:center;padding:24px">Ürün yok</td></tr>';
}
let editingProductId = null;
function openAddProduct() {
  editingProductId = null;
  document.getElementById('modal-product-title').textContent = 'YENİ ÜRÜN';
  ['p-emoji','p-name','p-price'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('p-cat').value='İçecek';
  openModal('modal-product');
}
function openEditProduct(id) {
  editingProductId = id;
  const p = PRODUCTS.find(x=>x.id===id);
  document.getElementById('modal-product-title').textContent = 'ÜRÜNÜ DÜZENLE';
  document.getElementById('p-emoji').value=p.emoji||'';
  document.getElementById('p-name').value=p.ad;
  document.getElementById('p-price').value=p.fiyat;
  document.getElementById('p-cat').value=p.kategori||'İçecek';
  openModal('modal-product');
}
async function saveProduct() {
  const ad = document.getElementById('p-name').value.trim();
  const fiyat = parseFloat(document.getElementById('p-price').value);
  if (!ad||isNaN(fiyat)) { toast('Ad ve fiyat zorunlu!',true); return; }
  const emoji = document.getElementById('p-emoji').value||'🛒';
  const kategori = document.getElementById('p-cat').value;
  try {
    if (editingProductId) await db('urunler','PATCH',{emoji,ad,fiyat,kategori},`?id=eq.${editingProductId}`);
    else await db('urunler','POST',{emoji,ad,fiyat,kategori});
    await loadAll(); closeModal('modal-product'); renderProducts(); toast('Ürün kaydedildi ✓');
  } catch(e) { toast('Hata: '+e.message,true); }
}
async function deleteProduct(id) {
  if (!confirm('Ürünü silmek istediğinizden emin misiniz?')) return;
  try {
    await db('urunler','DELETE',null,`?id=eq.${id}`);
    await loadAll(); renderProducts(); toast('Ürün silindi');
  } catch(e) { toast('Hata: '+e.message,true); }
}

// SALE
let cart = [];
function renderSalePage() {
  const sel = document.getElementById('sale-member');
  sel.innerHTML = '<option value="">— Üye seçin —</option>' +
    MEMBERS.map(m=>`<option value="${m.id}">${m.ad_soyad} (${Number(m.bakiye)>=0?'+':''}${fmtMoney(m.bakiye)})</option>`).join('');
  sel.onchange = updateSaleMemberInfo;
  updateSaleMemberInfo();
  document.getElementById('sale-products').innerHTML = PRODUCTS.map(p =>
    `<div class="product-card" onclick="addToCart(${p.id})">
      <div class="emoji">${p.emoji||'🛒'}</div>
      <div class="pname">${p.ad}</div>
      <div class="pprice">${fmtMoney(p.fiyat)}</div>
    </div>`).join('')||'<div style="color:var(--muted)">Ürün yok</div>';
  renderCart();
}
function updateSaleMemberInfo() {
  const id = parseInt(document.getElementById('sale-member').value);
  const m = MEMBERS.find(x=>x.id===id);
  const el = document.getElementById('sale-member-info');
  if (!m) { el.textContent=''; return; }
  const month = today().slice(0,7);
  const spent = TRANSACTIONS.filter(t=>t.uye_id===m.id&&t.tur==='satis'&&t.tarih.startsWith(month)).reduce((s,t)=>s+Number(t.tutar),0);
  const bal = Number(m.bakiye);
  el.innerHTML = `Bakiye: <span class="${bal>=0?'balance-pos':'balance-neg'} balance-chip">${bal>=0?'+':''}${fmtMoney(bal)}</span> &nbsp;|&nbsp; Bu ay: ${fmtMoney(spent)} / ${fmtMoney(m.aylik_limit)}`;
}
function addToCart(pid) {
  const p = PRODUCTS.find(x=>x.id===pid);
  const ex = cart.find(c=>c.id===pid);
  if (ex) ex.qty++; else cart.push({...p,qty:1});
  renderCart();
}
function removeFromCart(pid) { cart=cart.filter(c=>c.id!==pid); renderCart(); }
function clearCart() { cart=[]; renderCart(); }
function renderCart() {
  const total = cart.reduce((s,c)=>s+c.fiyat*c.qty,0);
  document.getElementById('cart-items').innerHTML = cart.map(c =>
    `<div class="cart-item"><span>${c.emoji||''} ${c.ad} x${c.qty}</span>
    <span style="display:flex;align-items:center;gap:8px">
      <span class="balance-chip" style="color:var(--text)">${fmtMoney(c.fiyat*c.qty)}</span>
      <button onclick="removeFromCart(${c.id})" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:14px">✕</button>
    </span></div>`).join('')||'<div style="color:var(--muted);font-size:13px;padding:8px 0">Sepet boş</div>';
  document.getElementById('cart-total').textContent = fmtMoney(total);
}
async function completeSale() {
  const memberId = parseInt(document.getElementById('sale-member').value);
  if (!memberId) { toast('Lütfen üye seçin!',true); return; }
  if (cart.length===0) { toast('Sepet boş!',true); return; }
  const m = MEMBERS.find(x=>x.id===memberId);
  const total = cart.reduce((s,c)=>s+c.fiyat*c.qty,0);
  const month = today().slice(0,7);
  const spent = TRANSACTIONS.filter(t=>t.uye_id===memberId&&t.tur==='satis'&&t.tarih.startsWith(month)).reduce((s,t)=>s+Number(t.tutar),0);
  if (spent+total>m.aylik_limit && Number(m.bakiye)<total) {
    if (!confirm(`${m.ad_soyad} aylık limitini aşıyor! Yine de devam edilsin mi?`)) return;
  }
  const aciklama = cart.map(c=>`${c.emoji||''}${c.ad}${c.qty>1?' x'+c.qty:''}`).join(', ');
  try {
    await db('uyeler','PATCH',{bakiye:Number(m.bakiye)-total},`?id=eq.${memberId}`);
    await db('islemler','POST',{uye_id:memberId,tur:'satis',tutar:total,tarih:today(),aciklama});
    await loadAll(); cart=[]; renderSalePage(); renderDashboard();
    toast(`Satış tamamlandı ✓ — ${fmtMoney(total)}`);
  } catch(e) { toast('Hata: '+e.message,true); }
}

// MONTH END
let pendingMonthEnd = null;
function populateMonthSelect(selId) {
  const sel = document.getElementById(selId);
  const now = new Date();
  sel.innerHTML = Array.from({length:12},(_,i)=>{
    const d = new Date(now.getFullYear(),now.getMonth()-i,1);
    const val = d.toISOString().slice(0,7);
    const label = d.toLocaleDateString('tr-TR',{month:'long',year:'numeric'});
    return `<option value="${val}">${label}</option>`;
  }).join('');
}
function renderMonthEnd() {
  populateMonthSelect('monthend-month');
  updateMonthEndTable();
  document.getElementById('monthend-month').onchange = updateMonthEndTable;
}
function updateMonthEndTable() {
  const month = document.getElementById('monthend-month').value;
  const rows = MEMBERS.map(m => {
    const spent = TRANSACTIONS.filter(t=>t.uye_id===m.id&&t.tur==='satis'&&t.tarih.startsWith(month)).reduce((s,t)=>s+Number(t.tutar),0);
    const over = spent>m.aylik_limit ? spent-m.aylik_limit : 0;
    return {m,spent,over};
  }).filter(r=>r.over>0);
  document.getElementById('monthend-table').innerHTML = rows.map(r => {
    const nextBal = Number(r.m.bakiye)-r.over;
    return `<tr>
      <td><strong>${r.m.ad_soyad}</strong></td>
      <td class="balance-chip" style="font-family:'JetBrains Mono',monospace">${fmtMoney(r.m.aylik_limit)}</td>
      <td><span class="balance-neg balance-chip">${fmtMoney(r.spent)}</span></td>
      <td><span class="badge neg">${fmtMoney(r.over)} aşım</span></td>
      <td><span class="${nextBal>=0?'balance-pos':'balance-neg'} balance-chip">${nextBal>=0?'+':''}${fmtMoney(nextBal)}</span></td>
    </tr>`;
  }).join('')||'<tr><td colspan="5" style="color:var(--muted);text-align:center;padding:24px">Bu ay limit aşımı olan üye yok 🎉</td></tr>';
  document.getElementById('monthend-month').dataset.rows = JSON.stringify(rows.map(r=>({id:r.m.id,over:r.over})));
}
function runMonthEnd() {
  const month = document.getElementById('monthend-month').value;
  const rowsRaw = document.getElementById('monthend-month').dataset.rows;
  if (!rowsRaw) return;
  const rows = JSON.parse(rowsRaw).filter(r=>r.over>0);
  if (rows.length===0) { toast('Limit aşımı olan üye yok'); return; }
  pendingMonthEnd = {month,rows};
  const label = new Date(month+'-01').toLocaleDateString('tr-TR',{month:'long',year:'numeric'});
  document.getElementById('monthend-confirm-text').innerHTML =
    `<strong>${label}</strong> ayı için <strong>${rows.length} üyenin</strong> limit aşımı devredilecek.<br><br>` +
    rows.map(r=>{const m=MEMBERS.find(x=>x.id===r.id);return `• ${m.ad_soyad}: <span style="color:var(--red)">-${fmtMoney(r.over)}</span>`;}).join('<br>');
  openModal('modal-monthend-confirm');
}
async function confirmMonthEnd() {
  if (!pendingMonthEnd) return;
  const d = new Date(pendingMonthEnd.month+'-01'); d.setMonth(d.getMonth()+1);
  const nextDate = d.toISOString().slice(0,10);
  try {
    for (const r of pendingMonthEnd.rows) {
      const m = MEMBERS.find(x=>x.id===r.id);
      await db('uyeler','PATCH',{bakiye:Number(m.bakiye)-r.over},`?id=eq.${r.id}`);
      await db('islemler','POST',{uye_id:r.id,tur:'devir',tutar:r.over,tarih:nextDate,aciklama:`${pendingMonthEnd.month} ay sonu devri`});
    }
    await loadAll(); closeModal('modal-monthend-confirm'); updateMonthEndTable(); renderDashboard();
    toast(`Ay sonu işlendi ✓ — ${pendingMonthEnd.rows.length} üye güncellendi`);
    pendingMonthEnd = null;
  } catch(e) { toast('Hata: '+e.message,true); }
}

// REPORT
function renderReport() {
  const month = document.getElementById('report-month').value;
  const txs = TRANSACTIONS.filter(t=>t.tarih.startsWith(month));
  const totalSales = txs.filter(t=>t.tur==='satis').reduce((s,t)=>s+Number(t.tutar),0);
  const totalLoads = txs.filter(t=>t.tur==='yukleme').reduce((s,t)=>s+Number(t.tutar),0);
  const totalRollovers = txs.filter(t=>t.tur==='devir').reduce((s,t)=>s+Number(t.tutar),0);
  document.getElementById('report-cards').innerHTML = `
    <div class="card"><div class="card-label">Toplam Satış</div><div class="card-value orange">${fmtMoney(totalSales)}</div></div>
    <div class="card"><div class="card-label">Yüklenen Bakiye</div><div class="card-value green">${fmtMoney(totalLoads)}</div></div>
    <div class="card"><div class="card-label">Devredilen Borç</div><div class="card-value red">${fmtMoney(totalRollovers)}</div></div>`;
  document.getElementById('report-table').innerHTML = txs.map(t=>{
    const m=MEMBERS.find(x=>x.id===t.uye_id);
    const badge=t.tur==='yukleme'?'<span class="badge pos">Yükleme</span>':t.tur==='devir'?'<span class="badge warn">Devir</span>':'<span class="badge neg">Satış</span>';
    const neg=t.tur==='satis'||t.tur==='devir';
    return `<tr><td>${m?m.ad_soyad:'—'}</td><td>${badge}</td><td><span class="balance-chip ${neg?'balance-neg':'balance-pos'}">${neg?'-':'+'}${fmtMoney(t.tutar)}</span></td><td style="color:var(--muted);font-size:13px">${fmt(t.tarih)}</td><td style="color:var(--muted);font-size:13px">${t.aciklama||'—'}</td></tr>`;
  }).join('')||'<tr><td colspan="5" style="color:var(--muted);text-align:center;padding:24px">Bu ayda işlem yok</td></tr>';
}
function exportCSV() {
  const month = document.getElementById('report-month').value;
  const txs = TRANSACTIONS.filter(t=>t.tarih.startsWith(month));
  const rows = [['Üye','Tür','Tutar','Tarih','Not']];
  txs.forEach(t=>{const m=MEMBERS.find(x=>x.id===t.uye_id);rows.push([m?m.ad_soyad:'?',t.tur,t.tutar,t.tarih,t.aciklama||'']);});
  const csv = rows.map(r=>r.map(c=>`"${c}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent('\uFEFF'+csv);
  a.download = `fitcafe-${month}.csv`; a.click(); toast('CSV indirildi ✓');
}

// INIT
(async () => {
  try {
    await loadAll();
    renderDashboard();
  } catch(e) {
    document.getElementById('dash-cards').innerHTML = `<div style="color:var(--red);padding:20px">⚠️ Bağlantı hatası: ${e.message}</div>`;
  }
})();
</script>
