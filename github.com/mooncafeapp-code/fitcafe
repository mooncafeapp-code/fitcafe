<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FitCafe — Üye Bakiye Sistemi</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0d0d; --surface: #161616; --surface2: #1e1e1e;
    --border: #2a2a2a; --accent: #c8f542; --accent2: #f5a342;
    --red: #ff4d4d; --text: #f0f0f0; --muted: #666; --radius: 12px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; font-size: 15px; }
  .layout { display: flex; min-height: 100vh; }
  .sidebar { width: 220px; min-width: 220px; background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; padding: 24px 0; position: sticky; top: 0; height: 100vh; }
  .logo { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 2px; color: var(--accent); padding: 0 24px 28px; border-bottom: 1px solid var(--border); line-height: 1; }
  .logo span { color: var(--muted); font-size: 13px; display: block; font-family: 'DM Sans', sans-serif; letter-spacing: 0; margin-top: 4px; }
  .nav { padding: 20px 0; flex: 1; }
  .nav-item { display: flex; align-items: center; gap: 10px; padding: 11px 24px; cursor: pointer; color: var(--muted); font-weight: 500; font-size: 14px; transition: all .2s; border-left: 3px solid transparent; }
  .nav-item:hover { color: var(--text); background: var(--surface2); }
  .nav-item.active { color: var(--accent); border-left-color: var(--accent); background: rgba(200,245,66,.06); }
  .nav-icon { font-size: 18px; width: 22px; text-align: center; }
  .main { flex: 1; padding: 32px; overflow-y: auto; }
  .page { display: none; }
  .page.active { display: block; }
  .page-title { font-family: 'Bebas Neue', sans-serif; font-size: 36px; letter-spacing: 2px; color: var(--accent); margin-bottom: 4px; }
  .page-sub { color: var(--muted); font-size: 13px; margin-bottom: 28px; }
  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 32px; }
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .card-label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
  .card-value { font-family: 'Bebas Neue', sans-serif; font-size: 36px; letter-spacing: 1px; }
  .card-value.green { color: var(--accent); }
  .card-value.orange { color: var(--accent2); }
  .card-value.red { color: var(--red); }
  .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .table-header { padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .table-header h3 { font-size: 14px; font-weight: 600; }
  table { width: 100%; border-collapse: collapse; }
  th { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); padding: 12px 20px; text-align: left; background: rgba(255,255,255,.02); border-bottom: 1px solid var(--border); }
  td { padding: 13px 20px; font-size: 14px; border-bottom: 1px solid rgba(255,255,255,.04); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,.02); }
  .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; letter-spacing: .5px; }
  .badge.pos { background: rgba(200,245,66,.15); color: var(--accent); }
  .badge.neg { background: rgba(255,77,77,.15); color: var(--red); }
  .badge.warn { background: rgba(245,163,66,.15); color: var(--accent2); }
  .btn { padding: 9px 18px; border-radius: 8px; border: none; font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; cursor: pointer; transition: all .15s; display: inline-flex; align-items: center; gap: 6px; }
  .btn-accent { background: var(--accent); color: #000; }
  .btn-accent:hover { background: #d6ff55; transform: translateY(-1px); }
  .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text); }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }
  .btn-red { background: rgba(255,77,77,.15); color: var(--red); border: 1px solid rgba(255,77,77,.3); }
  .btn-red:hover { background: rgba(255,77,77,.25); }
  .btn-sm { padding: 5px 12px; font-size: 12px; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: .8px; }
  .form-group input, .form-group select { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; color: var(--text); padding: 10px 14px; font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; transition: border-color .2s; }
  .form-group input:focus, .form-group select:focus { border-color: var(--accent); }
  .form-group select option { background: var(--surface2); }
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.7); z-index: 100; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 28px; width: 480px; max-width: 95vw; animation: slideUp .2s ease; }
  @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  .modal-title { font-family: 'Bebas Neue', sans-serif; font-size: 24px; letter-spacing: 1px; color: var(--accent); margin-bottom: 20px; }
  .modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }
  .search-bar { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 9px 14px; color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; width: 220px; }
  .search-bar:focus { border-color: var(--accent); }
  .balance-chip { font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; }
  .balance-pos { color: var(--accent); }
  .balance-neg { color: var(--red); }
  .balance-zero { color: var(--muted); }
  .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; }
  .product-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; cursor: pointer; transition: all .2s; text-align: center; }
  .product-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .product-card .emoji { font-size: 32px; margin-bottom: 8px; }
  .product-card .pname { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .product-card .pprice { font-family: 'JetBrains Mono', monospace; font-size: 15px; color: var(--accent); }
  .sale-layout { display: grid; grid-template-columns: 1fr 340px; gap: 20px; align-items: start; }
  .cart-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; position: sticky; top: 0; }
  .cart-title { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 1px; color: var(--accent); margin-bottom: 16px; }
  .cart-item { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 14px; }
  .cart-item:last-of-type { border-bottom: none; }
  .cart-total { display: flex; justify-content: space-between; padding: 14px 0 0; font-weight: 700; font-size: 15px; margin-top: 8px; border-top: 1px solid var(--border); }
  .cart-total .amount { font-family: 'JetBrains Mono', monospace; color: var(--accent); font-size: 18px; }
  .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .toast { position: fixed; bottom: 24px; right: 24px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 14px 20px; font-size: 14px; z-index: 999; display: none; animation: slideUp .2s ease; border-left: 3px solid var(--accent); }
  .toast.show { display: block; }
  .toast.error { border-left-color: var(--red); }
  .rollover-badge { background: rgba(255,77,77,.12); border: 1px solid rgba(255,77,77,.3); border-radius: 8px; padding: 10px 14px; font-size: 13px; color: var(--red); display: flex; align-items: center; gap: 8px; }
  .report-summary { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-bottom: 24px; }
  .month-controls { display: flex; gap: 12px; margin-bottom: 24px; align-items: center; }
  .month-controls select { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; color: var(--text); padding: 9px 14px; font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; }
  .loading { display: flex; align-items: center; justify-content: center; padding: 40px; color: var(--muted); gap: 10px; font-size: 14px; }
  .spinner { width: 18px; height: 18px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin .7s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .bottom-nav { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: var(--surface); border-top: 1px solid var(--border); z-index: 50; padding: 8px 0 12px; }
  .bottom-nav-inner { display: flex; justify-content: space-around; align-items: center; }
  .bnav-item { display: flex; flex-direction: column; align-items: center; gap: 3px; cursor: pointer; padding: 4px 10px; color: var(--muted); font-size: 11px; font-weight: 500; transition: color .15s; }
  .bnav-item.active { color: var(--accent); }
  .bnav-item .bnav-icon { font-size: 20px; }
  @media (max-width: 768px) {
    .sidebar { display: none; }
    .main { padding: 16px; padding-bottom: 90px; }
    .form-grid { grid-template-columns: 1fr; }
    .sale-layout { grid-template-columns: 1fr; }
    .report-summary { grid-template-columns: 1fr; }
    .cards { grid-template-columns: 1fr 1fr; }
    .bottom-nav { display: block; }
  }
</style>
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <div class="logo">FitCafe<span>Üye Bakiye Sistemi</span></div>
    <nav class="nav">
      <div class="nav-item active" onclick="goPage('dashboard')"><span class="nav-icon">📊</span> Panel</div>
      <div class="nav-item" onclick="goPage('members')"><span class="nav-icon">👥</span> Üyeler</div>
      <div class="nav-item" onclick="goPage('sale')"><span class="nav-icon">🛒</span> Satış Yap</div>
      <div class="nav-item" onclick="goPage('products')"><span class="nav-icon">🥤</span> Ürünler</div>
      <div class="nav-item" onclick="goPage('monthend')"><span class="nav-icon">📅</span> Ay Sonu</div>
      <div class="nav-item" onclick="goPage('report')"><span class="nav-icon">📈</span> Raporlar</div>
    </nav>
  </aside>
  <main class="main">
    <div class="page active" id="page-dashboard">
      <div class="page-title">PANEL</div>
      <div class="page-sub">Genel bakış</div>
      <div class="cards" id="dash-cards"><div class="loading"><div class="spinner"></div> Yükleniyor...</div></div>
      <div class="table-wrap">
        <div class="table-header"><h3>Son İşlemler</h3><span style="font-size:12px;color:var(--muted)" id="dash-tx-count"></span></div>
        <table><thead><tr><th>Üye</th><th>İşlem</th><th>Tutar</th><th>Tarih</th></tr></thead><tbody id="dash-tx"><tr><td colspan="4"><div class="loading"><div class="spinner"></div></div></td></tr></tbody></table>
      </div>
    </div>
    <div class="page" id="page-members">
      <div class="top-bar">
        <div><div class="page-title">ÜYELER</div><div class="page-sub">Üye bakiye yönetimi</div></div>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <input class="search-bar" placeholder="🔍 Üye ara..." oninput="renderMembers(this.value)">
          <button class="btn btn-accent" onclick="openAddMember()">+ Üye Ekle</button>
        </div>
      </div>
      <div class="table-wrap">
        <table><thead><tr><th>Ad Soyad</th><th>Telefon</th><th>Aylık Limit</th><th>Bakiye</th><th>Durum</th><th>İşlem</th></tr></thead><tbody id="members-table"><tr><td colspan="6"><div class="loading"><div class="spinner"></div></div></td></tr></tbody></table>
      </div>
    </div>
    <div class="page" id="page-sale">
      <div class="page-title">SATIŞ YAP</div>
      <div class="page-sub">Ürün seç → Üye seç → Tamamla</div>
      <div class="sale-layout">
        <div>
          <div style="margin-bottom:16px">
            <label style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;display:block;margin-bottom:8px">Üye Seç</label>
            <select id="sale-member" style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:10px 14px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;width:100%"></select>
            <div id="sale-member-info" style="margin-top:8px;font-size:13px;color:var(--muted)"></div>
          </div>
          <div style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:12px">Ürünler</div>
          <div class="product-grid" id="sale-products"><div class="loading"><div class="spinner"></div></div></div>
        </div>
        <div class="cart-box">
          <div class="cart-title">🛒 Sepet</div>
          <div id="cart-items"></div>
          <div class="cart-total"><span>Toplam</span><span class="amount" id="cart-total">₺0</span></div>
          <button class="btn btn-accent" style="width:100%;margin-top:16px;justify-content:center" onclick="completeSale()">✓ Satışı Tamamla</button>
          <button class="btn btn-outline" style="width:100%;margin-top:8px;justify-content:center" onclick="clearCart()">Sepeti Temizle</button>
        </div>
      </div>
    </div>
    <div class="page" id="page-products">
      <div class="top-bar">
        <div><div class="page-title">ÜRÜNLER</div><div class="page-sub">Menü yönetimi</div></div>
        <button class="btn btn-accent" onclick="openAddProduct()">+ Ürün Ekle</button>
      </div>
      <div class="table-wrap">
        <table><thead><tr><th>Emoji</th><th>Ürün Adı</th><th>Fiyat</th><th>Kategori</th><th>İşlem</th></tr></thead><tbody id="products-table"><tr><td colspan="5"><div class="loading"><div class="spinner"></div></div></td></tr></tbody></table>
      </div>
    </div>
    <div class="page" id="page-monthend">
      <div class="page-title">AY SONU</div>
      <div class="page-sub">Limitini dolduranları bir sonraki aya devreder</div>
      <div class="month-controls"><select id="monthend-month"></select><button class="btn btn-accent" onclick="runMonthEnd()">📅 Ay Sonunu Çalıştır</button></div>
      <div class="rollover-badge" style="margin-bottom:20px">⚠️ Bu işlem limit aşımlarını bir sonraki aya borç olarak devreder. Geri alınamaz!</div>
      <div class="table-wrap">
        <div class="table-header"><h3>Limitini Dolduran Üyeler</h3></div>
        <table><thead><tr><th>Üye</th><th>Aylık Limit</th><th>Bu Ay Harcama</th><th>Limit Aşımı</th><th>Sonraki Ay Başlangıç</th></tr></thead><tbody id="monthend-table"></tbody></table>
      </div>
    </div>
    <div class="page" id="page-report">
      <div class="page-title">RAPORLAR</div>
      <div class="page-sub">Aylık satış ve üye özeti</div>
      <div style="display:flex;gap:12px;margin-bottom:24px;align-items:center;flex-wrap:wrap">
        <select id="report-month" onchange="renderReport()" style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:9px 14px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;"></select>
        <button class="btn btn-outline" onclick="exportCSV()">📥 CSV İndir</button>
      </div>
      <div class="report-summary" id="report-cards"></div>
      <div class="table-wrap">
        <div class="table-header"><h3>Tüm İşlemler</h3></div>
        <table><thead><tr><th>Üye</th><th>İşlem</th><th>Tutar</th><th>Tarih</th><th>Not</th></tr></thead><tbody id="report-table"></tbody></table>
      </div>
    </div>
  </main>
</div>

<!-- MODALS -->
<div class="modal-overlay" id="modal-member">
  <div class="modal">
    <div class="modal-title" id="modal-member-title">YENİ ÜYE</div>
    <div class="form-grid">
      <div class="form-group" style="grid-column:span 2"><label>Ad Soyad *</label><input id="m-name" placeholder="Ahmet Yılmaz"></div>
